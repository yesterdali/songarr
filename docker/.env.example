# Copy to `.env` next to docker-compose.yml; docker compose loads it automatically.

# --- Discord bot (songarr-discord) ---
# Bot token from https://discord.com/developers/applications → your app → Bot.
DISCORD_TOKEN=
# Your test server's ID (Discord → Developer Mode on → right-click server →
# Copy Server ID). Slash commands register there instantly; leave empty for
# global registration (can take up to ~1h to appear).
DISCORD_TEST_GUILD=
# Where the bot reaches Songarr. Default works for this example's networking.
# If Songarr runs behind gluetun (network_mode: service:gluetun), set this to
# gluetun's published port, e.g. http://host.docker.internal:4534
SONGARR_URL=http://songarr-proxy:4534

# --- Optional Yandex Music integration (songarr-proxy) ---
SONGARR_YANDEX_ENABLED=false
SONGARR_YANDEX_ACCESS_TOKEN=
SONGARR_YANDEX_REFRESH_TOKEN=

# --- Optional VK Music integration (songarr-proxy) ---
# Lets the bot play pasted vk.com/audio… links. Get a token once with:
#   echo '{"login":"+7…","password":"…"}' | docker compose exec -T songarr-proxy songarr-vk login
SONGARR_VK_ENABLED=false
SONGARR_VK_ACCESS_TOKEN=
