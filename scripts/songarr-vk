#!/usr/bin/env python3
"""Songarr <-> VK Music JSON helper.

yt-dlp has no VK audio extractor, so pasted ``vk.com/audio…`` links are resolved
here. VK now requires Android-app *device check-in* to mint a token that can call
the audio API (a bare client_id/secret password grant returns invalid_client),
so we use vodka2's ``vkaudiotoken`` (get_kate_token → AndroidCheckin) and call
``audio.getById`` with the matching Kate user-agent at API v5.95.

Mirrors ``songarr-yandex``: one JSON object in on stdin, JSON out on stdout.
Get a token once with::

    docker compose exec songarr songarr-vk login    # interactive (no -T): prompts + 2FA
"""

from __future__ import annotations

import getpass
import json
import sys
from typing import Any

# The runtime image's locale isn't guaranteed UTF-8; without this, input() of a
# non-ASCII 2FA/captcha value crashes with a surrogate UnicodeEncodeError.
for _stream in (sys.stdin, sys.stdout, sys.stderr):
    try:
        _stream.reconfigure(encoding="utf-8", errors="replace")
    except Exception:
        pass


def fail(message: str, code: int = 1) -> None:
    print(message, file=sys.stderr)
    raise SystemExit(code)


try:
    import requests
    from vkaudiotoken import get_kate_token, supported_clients, TokenException
except Exception as exc:  # pragma: no cover - exercised in deployment, not tests
    fail(f"Cannot import vkaudiotoken. Install it: pip install vkaudiotoken ({exc})")

KATE_USER_AGENT = supported_clients.KATE.user_agent
API_VERSION = "5.95"  # vkaudiotoken's tested version for the audio methods


def read_payload() -> dict[str, Any]:
    raw = sys.stdin.read().strip()
    return json.loads(raw) if raw else {}


def _interactive() -> bool:
    return sys.stdin.isatty()


def _ask(label: str, given: Any, secret: bool = False) -> str:
    if given:
        return str(given)
    if not _interactive():
        fail(f"{label} is required (run interactively without -T, or pass it in the JSON)")
    value = getpass.getpass(f"{label}: ") if secret else input(f"{label}: ")
    return value.strip()


def vk_call(token: str, method: str, **params: Any) -> Any:
    session = requests.session()
    session.headers.update({"User-Agent": KATE_USER_AGENT})
    query = [("access_token", token), ("v", API_VERSION)] + [
        (key, value) for key, value in params.items()
    ]
    response = session.get(
        f"https://api.vk.com/method/{method}", params=query, timeout=20
    )
    data = response.json()
    if "error" in data:
        err = data["error"]
        fail(f"VK API error [{err.get('error_code')}]: {err.get('error_msg')}")
    return data["response"]


def get_audio(token: str, track_id: str) -> dict[str, Any]:
    items = vk_call(token, "audio.getById", audios=track_id)
    if not items:
        fail(
            f"VK audio {track_id} not found "
            "(token lacks access, or this id needs an access key the plain URL omits)"
        )
    return items[0]


def cover_url(audio: dict[str, Any]) -> str | None:
    thumb = (audio.get("album") or {}).get("thumb") or {}
    for key in ("photo_600", "photo_300", "photo_270", "photo_135"):
        if thumb.get(key):
            return thumb[key]
    return None


def serialize_track(audio: dict[str, Any]) -> dict[str, Any]:
    owner, aid = audio.get("owner_id"), audio.get("id")
    duration = audio.get("duration")
    return {
        "trackId": f"{owner}_{aid}" if owner is not None and aid is not None else None,
        "artist": audio.get("artist") or "Unknown artist",
        "title": audio.get("title") or "Unknown title",
        "album": (audio.get("album") or {}).get("title"),
        "durationMs": int(duration) * 1000 if duration else None,
        "artworkUrl": cover_url(audio),
    }


def _token_from(payload: dict[str, Any]) -> str:
    token = payload.get("accessToken") or payload.get("access_token")
    if not token:
        fail("accessToken is required")
    return str(token)


def cmd_track(payload: dict[str, Any]) -> None:
    token = _token_from(payload)
    track_id = payload.get("trackId") or payload.get("track_id")
    if not track_id:
        fail("trackId is required")
    print(json.dumps(serialize_track(get_audio(token, track_id)), ensure_ascii=False))


def cmd_download(payload: dict[str, Any]) -> None:
    token = _token_from(payload)
    track_id = payload.get("trackId") or payload.get("track_id")
    if not track_id:
        fail("trackId is required")
    audio = get_audio(token, track_id)
    url = audio.get("url")
    if not url:
        fail("VK returned no playable url (region/owner-locked, or token lacks access)")
    # VK serves audio as HLS (.m3u8); ffmpeg consumes it directly.
    codec = "hls" if ".m3u8" in url else "mp3"
    print(json.dumps({"url": url, "codec": codec}, ensure_ascii=False))


def cmd_login(payload: dict[str, Any]) -> None:
    login = _ask("VK login (phone or email)", payload.get("login"))
    password = _ask("VK password", payload.get("password"), secret=True)
    code = payload.get("code")

    try:
        result = get_kate_token(login, password, auth_code=str(code) if code else "GET_CODE")
    except TokenException as err:
        if getattr(err, "code", None) == TokenException.TWOFA_REQ:
            print("VK sent a 2FA code (SMS/app).", file=sys.stderr, flush=True)
            if not _interactive():
                fail('VK needs a 2FA code. Re-run with {"login","password","code"}.')
            entered = input("2FA code: ").strip()
            result = get_kate_token(login, password, auth_code=entered)
        else:
            fail(f"VK auth failed: {err}")

    token = result.get("token")
    if not token:
        fail("VK auth did not return a token")
    print(json.dumps({"accessToken": token}, ensure_ascii=False, indent=2))


COMMANDS = {
    "login": cmd_login,
    "track": cmd_track,
    "download": cmd_download,
}


def main() -> None:
    command = sys.argv[1] if len(sys.argv) > 1 else ""
    handler = COMMANDS.get(command)
    if not handler:
        fail("usage: songarr-vk <login|track|download>")
    try:
        # `login` is interactive (2FA prompt); don't block on stdin from a tty.
        payload = {} if (command == "login" and sys.stdin.isatty()) else read_payload()
        handler(payload)
    except SystemExit:
        raise
    except Exception as exc:
        fail(f"{type(exc).__name__}: {exc}")


if __name__ == "__main__":
    main()
